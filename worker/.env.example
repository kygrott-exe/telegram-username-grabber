# Copy to .env and fill in.

# The published (or preview) URL of your Lovable app.
APP_BASE_URL=https://project--f70afb84-469c-42a2-864f-f1552b1800d1.lovable.app

# Shared token — copy from Lovable Cloud > Secrets > WORKER_TOKEN.
WORKER_TOKEN=paste-value-here

# From https://my.telegram.org > API development tools
TG_API_ID=123456
TG_API_HASH=your_api_hash_here

# Anything you like. A file "<name>.session" will be created next to the script.
TG_SESSION_NAME=claimer

# Poll interval in seconds
POLL_INTERVAL=5
